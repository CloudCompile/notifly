# ─── GitHub OAuth ────────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers → New OAuth App
# Homepage URL: https://yourapp.vercel.app
# Authorization callback URL: https://yourapp.vercel.app/api/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Session ─────────────────────────────────────────────────────────────────
# Random 32-byte hex string. Generate with: openssl rand -hex 32
SESSION_SECRET=

# ─── Vercel KV ───────────────────────────────────────────────────────────────
# Vercel Dashboard → Storage → Create KV Store → env vars auto-injected
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generate with: npm run generate-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Email shown in push requests — use your own address
VAPID_SUBJECT=mailto:you@example.com

# ─── Pollinations ────────────────────────────────────────────────────────────
# Your app's public key from https://enter.pollinations.ai
# Only used to build the OAuth authorize URL — never sent in AI API calls
POLLINATIONS_APP_KEY=pk_
